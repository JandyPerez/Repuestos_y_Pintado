<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.shape.Line?>

<AnchorPane prefHeight="500.0" prefWidth="850.0" style="-fx-background-color: #F0F5FB;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.puestosypintado.controladores.ProveedorController">

    <children>

        <!-- HEADER BAR -->
        <Pane prefHeight="48.0" prefWidth="850.0" style="-fx-background-color: linear-gradient(from 0% 0% to 100% 0%, #0066CC, #00AA99);" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Label layoutX="20.0" layoutY="10.0" style="-fx-font-family: Impact; -fx-font-size: 20px; -fx-text-fill: #FFFFFF; -fx-font-weight: bold;" text="GESTION DE PROVEEDORES" />
                <Label layoutX="490.0" layoutY="17.0" style="-fx-font-family: Courier New; -fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.85); -fx-font-weight: bold;" text="FERRETERIA — REGISTRO DE PROVEEDORES" />
      
              <Button layoutX="784.0" layoutY="-2.0" maxWidth="Infinity" onAction="#irHome" prefHeight="50.0" prefWidth="67.0" style="-fx-background-color: rgb(255,255,255,0.25); -fx-border-color: #ffffff;" styleClass="nav-button" text="Home" textFill="WHITE" textOverrun="CLIP">
                  <font>
                      <Font name="System Bold" size="12.0" />
                  </font>
              </Button>
            </children>
        </Pane>

        <!-- MAIN SPLIT PANE -->
        <SplitPane dividerPositions="0.45" layoutY="48.0" prefHeight="446.0" prefWidth="850.0" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 0;" AnchorPane.bottomAnchor="6.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="48.0">
            <items>

                <!-- LEFT PANEL — TABLE -->
                <AnchorPane minHeight="0.0" minWidth="0.0" style="-fx-background-color: #E8F1F8; -fx-border-color: #0066CC; -fx-border-width: 0 2 0 0;">
                    <children>
                        <Label layoutX="10.0" layoutY="10.0" style="-fx-font-family: Courier New; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #0066CC;" text="LISTADO" />

                        <!-- FIX #21: colTelProv eliminado, tabla tiene: ID, EMPRESA, CONTACTO, CATEGORIA -->
                        <TableView fx:id="tvProveedores" layoutY="32.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #B3D9FF; -fx-border-width: 1; -fx-selection-bar: #0066CC; -fx-selection-bar-non-focused: #66B2FF; -fx-faint-focus-color: transparent;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="32.0">
                            <columns>
                                <TableColumn fx:id="colIdProv" prefWidth="50.0" text="ID" />
                                <TableColumn fx:id="colEmpresaProv" prefWidth="130.0" text="EMPRESA" />
                                <TableColumn fx:id="colContactoProv" prefWidth="100.0" text="CONTACTO" />
                                <TableColumn fx:id="colCategoriaProv" prefWidth="100.0" text="CATEGORIA" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </AnchorPane>

                <!-- RIGHT PANEL — FORM -->
                <AnchorPane minHeight="0.0" minWidth="0.0" style="-fx-background-color: #F8FCFF;">
                    <children>

                        <!-- ID PROVEEDOR -->
                        <Label layoutX="20.0" layoutY="18.0" style="-fx-font-family: Courier New; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #0066CC;" text="ID PROVEEDOR" />
                        <TextField fx:id="txtIdProv" layoutX="120.0" layoutY="12.0" prefHeight="28.0" prefWidth="80.0" style="-fx-background-color: #F0F5FB; -fx-border-color: transparent transparent #0066CC transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #003D99; -fx-font-family: Courier New; -fx-font-size: 12px;" />
                        <Button layoutX="208.0" layoutY="12.0" onAction="#fnBuscarProveedor" prefHeight="28.0" prefWidth="34.0" style="-fx-background-color: #0066CC; -fx-text-fill: #FFFFFF; -fx-font-size: 13px; -fx-background-radius: 2;" text="🔍">
