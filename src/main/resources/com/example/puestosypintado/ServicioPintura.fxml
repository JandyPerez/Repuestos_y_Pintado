<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="700.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.puestosypintado.controladores.PinturaController">
    <children>
        <SplitPane dividerPositions="0.35" prefHeight="700.0" prefWidth="900.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <items>
                <AnchorPane minHeight="0.0" minWidth="0.0">
                    <children>
                        <TableView fx:id="tvOrdenes" prefHeight="200.0" prefWidth="200.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                            <columns>
                                <TableColumn fx:id="colOT" prefWidth="60.0" text="ID #" />
                                <TableColumn fx:id="colVehiculo" prefWidth="120.0" text="Vehículo" />
                                <TableColumn fx:id="colEstado" prefWidth="120.0" text="Etapa" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </AnchorPane>

                <ScrollPane fitToWidth="true">
                    <content>
                        <VBox spacing="15.0">
                            <children>
                                <Label text="Servicio de Pintura">
                                    <font><Font name="System Bold" size="18.0" /></font>
                                </Label>

                                <GridPane hgap="10.0" vgap="10.0">
                                    <columnConstraints>
                                        <ColumnConstraints minWidth="100.0" prefWidth="120.0" />
                                        <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" />
                                    </columnConstraints>
                                    <children>
                                        <Label text="No. OT" />
                                        <HBox spacing="5.0" GridPane.columnIndex="1">
                                            <TextField fx:id="txtIdOT" disable="true" prefWidth="80.0" />
                                            <Button fx:id="btnBuscarOT" onAction="#fnBuscarOT" text="🔍" />
                                        </HBox>

                                        <Label text="Vehículo / VIN" GridPane.rowIndex="1" />
                                        <ComboBox fx:id="cmbVehiculo" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                        <Label text="Piezas General" GridPane.rowIndex="2" />
                                        <TextField fx:id="txtPiezas" promptText="Separe por comas ej: Puerta, Bomper" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                        <Label text="Presupuesto Base" GridPane.rowIndex="3" />
                                        <HBox spacing="10.0" GridPane.columnIndex="1" GridPane.rowIndex="3">
                                            <TextField fx:id="txtPresupuesto" prefWidth="100.0" promptText="\$ 0.00" />
                                            <Label text="Anticipo: " />
                                            <TextField fx:id="txtAnticipo" disable="true" prefWidth="100.0" />
                                        </HBox>
                                    </children>
                           <rowConstraints>
                              <RowConstraints />
                              <RowConstraints />
                              <RowConstraints />
                              <RowConstraints />
                           </rowConstraints>
                                </GridPane>

                                <Separator prefWidth="200.0" />

                                <VBox spacing="15.0" style="-fx-border-color: #cccccc; -fx-border-radius: 5; -fx-padding: 15; -fx-background-color: #f9f9f9;">
                                    <children>
                                        <Label text="Detalle y Aclaración de Subservicios" textFill="#2c3e50">
                                            <font><Font name="System Bold Italic" size="14.0" /></font>
                                        </Label>

                                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                                            <Label text="Seleccionar Pieza:" />
                                            <ComboBox fx:id="cmbPiezaSeleccionada" prefWidth="150.0" promptText="Elegir pieza..." />
                                            <Label text="Costo Pieza (100-300):" />
                                            <TextField fx:id="txtCostoPiezaIndividual" prefWidth="70.0" text="150" />
                                        </HBox>

                                        <FlowPane hgap="15.0" vgap="10.0">
                                            <children>
                                                <CheckBox fx:id="chkLimpieza" text="Limpieza ($150)" />
                                                <CheckBox fx:id="chkLijado" text="Lijado ($150)" />
                                                <CheckBox fx:id="chkImprimacion" text="Imprimación ($150)" />
                                                <CheckBox fx:id="chkBarnizado" text="Barnizado ($150)" />
                                            </children>
                                        </FlowPane>

                                        <Button onAction="#fnAgregarSubservicio" style="-fx-background-color: #3498db; -fx-cursor: hand;" text="Añadir Detalle de Pieza" textFill="WHITE" />

                                        <TableView fx:id="tvSubservicios" prefHeight="150.0">
                                            <columns>
                                                <TableColumn fx:id="colDetallePieza" prefWidth="120" text="Pieza" />
                                                <TableColumn fx:id="colServicios" prefWidth="280" text="Servicios Aplicados" />
                                                <TableColumn fx:id="colCostoSub" prefWidth="100" text="Costo Total" />
                                            </columns>
                                        </TableView>

                                        <HBox alignment="CENTER_RIGHT">
                                            <Label text="Total Subservicios: ">
                                                <font><Font name="System Bold" size="14.0" /></font>
                                            </Label>
                                            <Label fx:id="lblTotalSubservicios" text="" textFill="#e74c3c">
                                                <font><Font name="System Bold" size="14.0" /></font>
                                            </Label>
                                        </HBox>
                                    </children>
                                </VBox>

                                <HBox alignment="CENTER" spacing="15.0">
                                    <children>
                                        <Button onAction="#fnGuardarOT" prefWidth="100.0" style="-fx-background-color: #95de9f; -fx-cursor: hand;" text="Guardar" />
                                        <Button onAction="#fnModificarOT" prefWidth="100.0" style="-fx-background-color: #fff495; -fx-cursor: hand;" text="Actualizar" />
                                        <Button onAction="#fnLimpiar" prefWidth="100.0" style="-fx-background-color: #7ee0e0; -fx-cursor: hand;" text="Limpiar" />
                                    </children>
                                </HBox>
                            </children>
                     <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                     </padding>
                        </VBox>
                    </content>
                </ScrollPane>
            </items>
        </SplitPane>
    </children>
</AnchorPane>
