<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<AnchorPane prefHeight="470.0" prefWidth="750.0" style="-fx-background-color: #F0F5FB;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.puestosypintado.controladores.ClientesControlador">

    <children>

        <!-- ══ HEADER BAR ══ -->
        <Pane prefHeight="48.0" prefWidth="750.0" style="-fx-background-color: linear-gradient(from 0% 0% to 100% 0%, #0066CC, #00AA99);" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Label layoutX="20.0" layoutY="10.0" style="-fx-font-family: 'Impact'; -fx-font-size: 20px;                            -fx-text-fill: #FFFFFF; -fx-font-weight: bold;" text="🔧  GESTIÓN DE CLIENTES" />
                <Label layoutX="430.0" layoutY="17.0" style="-fx-font-family: 'Courier New'; -fx-font-size: 10px;                            -fx-text-fill: rgba(255,255,255,0.85); -fx-font-weight: bold;" text="FERRETERÍA — REGISTRO DE CLIENTES" />
            </children>
        </Pane>

        <!-- ══ MAIN SPLIT PANE ══ -->
        <SplitPane dividerPositions="0.38" layoutY="48.0" prefHeight="416.0" prefWidth="750.0" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 0;" AnchorPane.bottomAnchor="6.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="48.0">
            <items>

                <!-- ══ LEFT PANEL — TABLE ══ -->
                <AnchorPane minHeight="0.0" minWidth="0.0" style="-fx-background-color: #E8F1F8; -fx-border-color: #0066CC;                            -fx-border-width: 0 2 0 0;">
                    <children>
                        <Label layoutX="10.0" layoutY="10.0" style="-fx-font-family: 'Courier New'; -fx-font-size: 11px;                                    -fx-font-weight: bold; -fx-text-fill: #0066CC;" text="▌ LISTADO" />

                        <TableView fx:id="tvclientes" layoutY="32.0" style="-fx-background-color: #FFFFFF;                                    -fx-border-color: #B3D9FF; -fx-border-width: 1;                                    -fx-selection-bar: #0066CC;                                    -fx-selection-bar-non-focused: #66B2FF;                                    -fx-faint-focus-color: transparent;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="32.0">
                            <columns>
                                <TableColumn fx:id="colcedula" prefWidth="100.0" text="CÉDULA/RNC" />
                                <TableColumn fx:id="colnombre" prefWidth="175.0" text="NOMBRE CLIENTE" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </AnchorPane>

                <!-- ══ RIGHT PANEL — FORM ══ -->
                <AnchorPane minHeight="0.0" minWidth="0.0" style="-fx-background-color: #F8FCFF;">
                    <children>

                        <!-- ── ID CLIENTE ── -->
                        <Label layoutX="20.0" layoutY="18.0" style="-fx-font-family: 'Courier New'; -fx-font-size: 10px;                                    -fx-font-weight: bold; -fx-text-fill: #0066CC;" text="ID CLIENTE" />
                        <TextField fx:id="txtid_Cliente" layoutX="110.0" layoutY="12.0" prefHeight="28.0" prefWidth="80.0" promptText="AUTO" style="-fx-background-color: #FFFFFF;                                    -fx-border-color: transparent transparent #0066CC transparent;                                    -fx-border-width: 0 0 2 0;                                    -fx-text-fill: #003D99;                                    -fx-font-family: 'Courier New'; -fx-font-size: 12px;                                    -fx-prompt-text-fill: #9999CC;" />
                        <Button fx:id="btnBuscar" layoutX="198.0" layoutY="12.0" onAction="#fnBuscarCliente" prefHeight="28.0" prefWidth="34.0" style="-fx-background-color: #0066CC; -fx-text-fill: #FFFFFF;                                    -fx-font-size: 13px; -fx-background-radius: 2;" text="🔍">
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                        </Button>

                        <!-- ── SEPARATOR 1 ── -->
                        <Line endX="400.0" endY="0.0" layoutY="50.0" startX="20.0" startY="0.0" style="-fx-stroke: #0066CC; -fx-opacity: 0.3;" />

                        <!-- ── NOMBRE ── -->
                        <Label layoutX="20.0" layoutY="63.0" prefWidth="60.0" style="-fx-font-family: 'Courier New'; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="NOMBRE " />
                        <TextField fx:id="txtnombre" layoutX="110.0" layoutY="59.0" prefHeight="28.0" prefWidth="260.0" style="-fx-background-color: #FFFFFF;                                    -fx-border-color: transparent transparent #D9E8F5 transparent;                                    -fx-border-width: 0 0 2 0;                                    -fx-text-fill: #1A1A1A;                                    -fx-font-family: 'Courier New'; -fx-font-size: 12px;" />

                        <!-- ── CÉDULA/RNC ── -->
                        <Label layoutX="20.0" layoutY="101.0" style="-fx-font-family: 'Courier New'; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="CÉDULA/RNC" />
                        <TextField fx:id="txtcedula" layoutX="110.0" layoutY="97.0" prefHeight="28.0" prefWidth="260.0" style="-fx-background-color: #FFFFFF;                                    -fx-border-color: transparent transparent #D9E8F5 transparent;                                    -fx-border-width: 0 0 2 0;                                    -fx-text-fill: #1A1A1A;                                    -fx-font-family: 'Courier New'; -fx-font-size: 12px;" />

                        <!-- ── TELÉFONO ── -->
                        <Label layoutX="20.0" layoutY="139.0" style="-fx-font-family: 'Courier New'; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="TELÉFONO " />
                        <TextField fx:id="txttelefono" layoutX="110.0" layoutY="135.0" prefHeight="28.0" prefWidth="260.0" style="-fx-background-color: #FFFFFF;                                    -fx-border-color: transparent transparent #D9E8F5 transparent;                                    -fx-border-width: 0 0 2 0;                                    -fx-text-fill: #1A1A1A;                                    -fx-font-family: 'Courier New'; -fx-font-size: 12px;" />

                        <!-- ── EMAIL ── -->
                        <Label layoutX="20.0" layoutY="177.0" style="-fx-font-family: 'Courier New'; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="EMAIL" />
                        <TextField fx:id="txtemail" layoutX="110.0" layoutY="173.0" prefHeight="28.0" prefWidth="260.0" promptText="correo@ejemplo.com" style="-fx-background-color: #FFFFFF;                                    -fx-border-color: transparent transparent #D9E8F5 transparent;                                    -fx-border-width: 0 0 2 0;                                    -fx-text-fill: #1A1A1A;                                    -fx-font-family: 'Courier New'; -fx-font-size: 12px;                                    -fx-prompt-text-fill: #9999CC;" />

                        <!-- ── DIRECCIÓN ── -->
                        <Label layoutX="20.0" layoutY="215.0" style="-fx-font-family: 'Courier New'; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="DIRECCIÓN" />
                        <TextField fx:id="txtdireccion" layoutX="110.0" layoutY="211.0" prefHeight="28.0" prefWidth="260.0" style="-fx-background-color: #FFFFFF;                                    -fx-border-color: transparent transparent #D9E8F5 transparent;                                    -fx-border-width: 0 0 2 0;                                    -fx-text-fill: #1A1A1A;                                    -fx-font-family: 'Courier New'; -fx-font-size: 12px;" />

                        <!-- ── PROVINCIA + SECTOR ── -->
                        <Label layoutX="20.0" layoutY="255.0" style="-fx-font-family: 'Courier New'; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="PROVINCIA" />
                        <ComboBox fx:id="cmbProvincia" layoutX="110.0" layoutY="251.0" prefHeight="28.0" prefWidth="87.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #B3D9FF;                                    -fx-border-width: 1;" />

                        <Label layoutX="214.0" layoutY="257.0" style="-fx-font-family: 'Courier New'; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="SECTOR" />
                        <ComboBox fx:id="cmbSector" layoutX="270.0" layoutY="251.0" prefHeight="28.0" prefWidth="100.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #B3D9FF;                                    -fx-border-width: 1;" />

                        <!-- ── ESTADO ── -->
                        <Label layoutX="20.0" layoutY="295.0" style="-fx-font-family: 'Courier New'; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="ESTADO" />
                        <ComboBox fx:id="cmbestado" layoutX="110.0" layoutY="291.0" prefHeight="28.0" prefWidth="160.0" promptText="Activo / Inactivo" style="-fx-background-color: #FFFFFF; -fx-border-color: #0066CC;                                    -fx-border-width: 1;" />

                        <!-- ── SEPARATOR 2 ── -->
                        <Line endX="400.0" endY="0.0" layoutY="333.0" startX="20.0" startY="0.0" style="-fx-stroke: #0066CC; -fx-opacity: 0.3;" />

                        <!-- ── ACTION BUTTONS ══ -->
                        <HBox alignment="CENTER" layoutX="10.0" layoutY="343.0" prefHeight="42.0" prefWidth="420.0" spacing="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0">
                            <children>
                                <Button mnemonicParsing="false" onAction="#fnGuardarCliente" prefHeight="34.0" prefWidth="90.0" style="-fx-background-color: #00AA77; -fx-text-fill: #FFFFFF; -fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-font-weight: bold; -fx-border-color: #009966; -fx-border-width: 1; -fx-background-radius: 2; -fx-border-radius: 2;" text="💾  GUARDAR">
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                </Button>
                                <Button mnemonicParsing="false" onAction="#fnModificarCliente" prefHeight="34.0" prefWidth="90.0" style="-fx-background-color: #0066CC; -fx-text-fill: #FFFFFF; -fx-font-family: 'Courier New'; -fx-font-size: 11.5px; -fx-font-weight: bold; -fx-border-color: #0052A3; -fx-border-width: 1; -fx-background-radius: 2; -fx-border-radius: 2;" text="✏  EDITAR">
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                </Button>
                                <Button mnemonicParsing="false" onAction="#fnBorrarCliente" prefHeight="34.0" prefWidth="90.0" style="-fx-background-color: #FF6B6B; -fx-text-fill: #FFFFFF; -fx-font-family: 'Courier New'; -fx-font-size: 11.5px; -fx-font-weight: bold; -fx-border-color: #E63939; -fx-border-width: 1; -fx-background-radius: 2; -fx-border-radius: 2;" text="🗑  BORRAR">
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                </Button>
                                <Button mnemonicParsing="false" onAction="#fnLimpiar" prefHeight="34.0" prefWidth="90.0" style="-fx-background-color: #00AA99; -fx-text-fill: #FFFFFF; -fx-font-family: 'Courier New'; -fx-font-size: 11.5px; -fx-font-weight: bold; -fx-border-color: #008877; -fx-border-width: 1; -fx-background-radius: 2; -fx-border-radius: 2;" text="⟳  LIMPIAR">
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                </Button>
                            </children>
                        </HBox>

                    </children>
                </AnchorPane>

            </items>
        </SplitPane>

        <!-- ══ BOTTOM ACCENT STRIP ══ -->
        <Pane prefHeight="6.0" prefWidth="750.0" style="-fx-background-color: linear-gradient(from 0% 0% to 100% 0%, #0066CC, #00AA99);" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" />

    </children>
</AnchorPane>
