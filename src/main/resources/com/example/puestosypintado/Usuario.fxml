<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="500.0" prefWidth="850.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.puestosypintado.controladores.UsuarioController">
    <children>
        <SplitPane dividerPositions="0.45" prefHeight="500.0" prefWidth="850.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <items>
                <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="160.0" prefWidth="100.0">
                    <children>
                        <TableView fx:id="tvUsuarios" prefHeight="200.0" prefWidth="200.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                            <columns>
                                <TableColumn fx:id="colIdUsuario" prefWidth="50.0" text="ID" />
                                <TableColumn fx:id="colUsuario" prefWidth="130.0" text="Usuario" />
                                <TableColumn fx:id="colRol" prefWidth="110.0" text="Rol" />
                                <TableColumn fx:id="colEstado" prefWidth="80.0" text="Estado" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </AnchorPane>

                <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="160.0" prefWidth="100.0">
                    <children>
                        <Label layoutX="17.0" layoutY="20.0" text="Gestión de Usuarios">
                            <font><Font name="Elephant" size="17.0" /></font>
                        </Label>

                        <Label layoutX="34.0" layoutY="112.0" text="ID Usuario" />
                        <TextField fx:id="txtIdUsuario" editable="false" layoutX="130.0" layoutY="107.0" prefHeight="26.0" prefWidth="95.0" />

                        <Label layoutX="40.0" layoutY="151.0" text="Nombre" />
                        <TextField fx:id="txtNombre" layoutX="130.0" layoutY="147.0" prefWidth="280.0" />

                        <Label layoutX="40.0" layoutY="193.0" text="Apellido" />
                        <TextField fx:id="txtApellido" layoutX="130.0" layoutY="189.0" prefWidth="280.0" />

                        <Label layoutX="242.0" layoutY="112.0" text="Usuario" />
                        <TextField fx:id="txtUsuario" layoutX="295.0" layoutY="107.0" prefHeight="26.0" prefWidth="134.0" />
                        <Button layoutX="295.0" layoutY="56.0" mnemonicParsing="false" onAction="#fnBuscarUsuario" style="-fx-cursor: hand;" text="🔍 Buscar" />

                        <Label layoutX="40.0" layoutY="230.0" text="Contraseña" />
                        <PasswordField fx:id="txtContrasena" layoutX="130.0" layoutY="226.0" prefWidth="280.0" />

                        <Label layoutX="40.0" layoutY="270.0" text="Rol" />
                        <ComboBox fx:id="cmbRol" layoutX="130.0" layoutY="266.0" prefWidth="280.0" />

                        <Label layoutX="40.0" layoutY="310.0" text="Estado" />
                        <ComboBox fx:id="cmbEstado" layoutX="130.0" layoutY="306.0" prefWidth="280.0" />

                        <HBox alignment="CENTER" layoutX="10.0" layoutY="400.0" prefHeight="35.0" prefWidth="440.0" spacing="15.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0">
                            <children>
                                <Button mnemonicParsing="false" onAction="#fnGuardarUsuario" prefHeight="25.0" prefWidth="80.0" style="-fx-background-color: rgb(149, 222, 159, 0.5); -fx-cursor: hand;" text="Guardar" textFill="#44865a" />
                                <Button mnemonicParsing="false" onAction="#fnModificarUsuario" prefHeight="25.0" prefWidth="80.0" style="-fx-background-color: rgb(255, 244, 149, 0.5); -fx-cursor: hand;" text="Editar" textFill="#9ea14d" />
                                <Button mnemonicParsing="false" onAction="#fnBorrarUsuario" prefHeight="25.0" prefWidth="80.0" style="-fx-background-color: rgb(255, 130, 130, 0.5); -fx-cursor: hand;" text="Borrar" textFill="#904545" />
                                <Button mnemonicParsing="false" onAction="#fnLimpiarUsuario" prefHeight="25.0" prefWidth="80.0" style="-fx-background-color: rgb(126, 190, 224, 0.5); -fx-cursor: hand;" text="Limpiar" textFill="#4da198" />
                            </children>
                        </HBox>
                    </children>
                </AnchorPane>
            </items>
        </SplitPane>
    </children>
</AnchorPane>
