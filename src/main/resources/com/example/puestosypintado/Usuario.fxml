<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.shape.Line?>

<AnchorPane prefHeight="435.0" prefWidth="850.0" style="-fx-background-color: #F0F5FB;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.puestosypintado.controladores.UsuarioController">

    <children>

        <!-- ══ HEADER BAR ══ -->
        <Pane prefHeight="48.0" prefWidth="850.0" style="-fx-background-color: linear-gradient(from 0% 0% to 100% 0%, #0066CC, #00AA99);" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Label layoutX="20.0" layoutY="10.0" style="-fx-font-family: 'Impact'; -fx-font-size: 20px; -fx-text-fill: #FFFFFF; -fx-font-weight: bold;" text="🔑  GESTIÓN DE USUARIOS" />
                <Label layoutX="490.0" layoutY="17.0" style="-fx-font-family: 'Courier New'; -fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.85); -fx-font-weight: bold;" text="FERRETERÍA — CONTROL DE ACCESO" />
            </children>
        </Pane>

        <!-- ══ MAIN SPLIT PANE ══ -->
        <SplitPane dividerPositions="0.45" layoutY="48.0" prefHeight="446.0" prefWidth="850.0" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 0;" AnchorPane.bottomAnchor="6.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="48.0">
            <items>

                <!-- ══ LEFT PANEL — TABLE ══ -->
                <AnchorPane minHeight="0.0" minWidth="0.0" style="-fx-background-color: #E8F1F8; -fx-border-color: #0066CC; -fx-border-width: 0 2 0 0;">
                    <children>
                        <Label layoutX="10.0" layoutY="10.0" style="-fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #0066CC;" text="▌ LISTADO" />

                        <TableView fx:id="tvUsuario" layoutY="32.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #B3D9FF; -fx-border-width: 1; -fx-selection-bar: #0066CC; -fx-selection-bar-non-focused: #66B2FF; -fx-faint-focus-color: transparent;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="32.0">
                            <columns>
                                <TableColumn fx:id="colIdUsuario" prefWidth="50.0" text="ID" />
                                <TableColumn fx:id="colUsuario" prefWidth="130.0" text="USUARIO" />
                                <TableColumn fx:id="colRol" prefWidth="110.0" text="ROL" />
                                <TableColumn fx:id="colestado" prefWidth="80.0" text="ESTADO" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </AnchorPane>

                <!-- ══ RIGHT PANEL — FORM ══ -->
                <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="426.0" prefWidth="463.0" style="-fx-background-color: #F8FCFF;">
                    <children>

                        <!-- ── BUSCAR USUARIO ── -->
                        <Label layoutX="20.0" layoutY="18.0" style="-fx-font-family: 'Courier New'; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #0066CC;" text="BUSCAR" />
                        <Button layoutX="70.0" layoutY="12.0" onAction="#fnBuscarUsuario" prefHeight="28.0" prefWidth="110.0" style="-fx-background-color: #0066CC; -fx-text-fill: #FFFFFF; -fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-font-weight: bold; -fx-background-radius: 2;" text="🔍  BUSCAR">
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                        </Button>

                        <!-- ── SEPARATOR 1 ── -->
                        <Line endX="430.0" endY="0.0" layoutY="50.0" startX="20.0" startY="0.0" style="-fx-stroke: #0066CC; -fx-opacity: 0.3;" />

                        <!-- ── ID USUARIO + USUARIO ── -->
                        <Label layoutX="20.0" layoutY="63.0" style="-fx-font-family: 'Courier New'; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="ID USUARIO" />
                        <TextField fx:id="txtIdUsuario" layoutX="115.0" layoutY="59.0" prefHeight="28.0" prefWidth="95.0" style="-fx-background-color: #F0F5FB; -fx-border-color: transparent transparent #0066CC transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #003D99; -fx-font-family: 'Courier New'; -fx-font-size: 12px;" />

                        <Label layoutX="20.0" layoutY="105.0" style="-fx-font-family: 'Courier New'; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="ID EMPLEADO" />
                        <TextField fx:id="txtIdEmpleado" layoutX="112.0" layoutY="97.0" prefHeight="28.0" prefWidth="51.0" style="-fx-background-color: #F0F5FB; -fx-border-color: transparent transparent #0066CC transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #003D99; -fx-font-family: 'Courier New'; -fx-font-size: 12px;" />

                        <Label layoutX="228.0" layoutY="63.0" style="-fx-font-family: 'Courier New'; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="USUARIO" />
                        <TextField fx:id="txtUsuario" layoutX="295.0" layoutY="59.0" prefHeight="28.0" prefWidth="140.0" style="-fx-background-color: #FFFFFF; -fx-border-color: transparent transparent #D9E8F5 transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #1A1A1A; -fx-font-family: 'Courier New'; -fx-font-size: 12px;" />

                        <!-- ── NOMBRE ── -->
                        <Label layoutX="178.0" layoutY="103.0" style="-fx-font-family: 'Courier New'; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="NOMBRE" />
                        <ComboBox fx:id="cmbNombre" layoutX="235.0" layoutY="99.0" onAction="#seleccionarEmpleado" prefHeight="28.0" prefWidth="200.0" style="-fx-background-color: #FFFFFF; -fx-border-color: transparent transparent #D9E8F5 transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #1A1A1A; -fx-font-family: 'Courier New'; -fx-font-size: 12px;" />

                        <!-- ── APELLIDO ── -->
<!--                        <Label layoutX="20.0" layoutY="139.0" style="-fx-font-family: 'Courier New'; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="APELLIDO" />-->
<!--                        <TextField fx:id="txtApellido" layoutX="115.0" layoutY="135.0" prefHeight="28.0" prefWidth="320.0" style="-fx-background-color: #FFFFFF; -fx-border-color: transparent transparent #D9E8F5 transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #1A1A1A; -fx-font-family: 'Courier New'; -fx-font-size: 12px;" />-->

                        <!-- ── CONTRASEÑA ── -->
                        <Label layoutX="20.0" layoutY="147.0" style="-fx-font-family: 'Courier New'; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="CONTRASEÑA" />
                        <PasswordField fx:id="txtContrasena" layoutX="115.0" layoutY="143.0" prefHeight="28.0" prefWidth="320.0" style="-fx-background-color: #FFFFFF; -fx-border-color: transparent transparent #D9E8F5 transparent; -fx-border-width: 0 0 2 0; -fx-font-family: 'Courier New'; -fx-font-size: 12px;" />

                        <!-- ── ROL ── -->
                        <Label layoutX="20.0" layoutY="185.0" style="-fx-font-family: 'Courier New'; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="ROL" />
                        <ComboBox fx:id="cmbRol" layoutX="115.0" layoutY="181.0" prefHeight="28.0" prefWidth="320.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #B3D9FF; -fx-border-width: 1;" />

                        <!-- ── ESTADO ── -->
                        <Label layoutX="20.0" layoutY="223.0" style="-fx-font-family: 'Courier New'; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="ESTADO" />
                        <ComboBox fx:id="cmbestado" layoutX="115.0" layoutY="219.0" prefHeight="28.0" prefWidth="175.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #0066CC; -fx-border-width: 1;" />

                        <!-- ── SEPARATOR 2 ── -->
                        <Line endX="430.0" endY="0.0" layoutY="273.0" startX="20.0" startY="0.0" style="-fx-stroke: #0066CC; -fx-opacity: 0.3;" />

                        <!-- ── ACTION BUTTONS ── -->
                        <HBox alignment="CENTER" layoutX="10.0" layoutY="292.0" prefHeight="42.0" prefWidth="455.0" spacing="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0">
                            <children>
                                <Button mnemonicParsing="false" onAction="#fnGuardarUsuario" prefHeight="34.0" prefWidth="90.0" style="-fx-background-color: #00AA77; -fx-text-fill: #FFFFFF; -fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-font-weight: bold; -fx-border-color: #009966; -fx-border-width: 1; -fx-background-radius: 2; -fx-border-radius: 2;" text="💾  GUARDAR">
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                </Button>
                                <Button mnemonicParsing="false" onAction="#fnModificarUsuario" prefHeight="34.0" prefWidth="90.0" style="-fx-background-color: #0066CC; -fx-text-fill: #FFFFFF; -fx-font-family: 'Courier New'; -fx-font-size: 11.5px; -fx-font-weight: bold; -fx-border-color: #0052A3; -fx-border-width: 1; -fx-background-radius: 2; -fx-border-radius: 2;" text="✏  EDITAR">
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                </Button>
                                <Button mnemonicParsing="false" onAction="#fnBorrarUsuario" prefHeight="34.0" prefWidth="90.0" style="-fx-background-color: #FF6B6B; -fx-text-fill: #FFFFFF; -fx-font-family: 'Courier New'; -fx-font-size: 11.5px; -fx-font-weight: bold; -fx-border-color: #E63939; -fx-border-width: 1; -fx-background-radius: 2; -fx-border-radius: 2;" text="🗑  BORRAR">
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                </Button>
                                <Button mnemonicParsing="false" onAction="#fnLimpiarUsuario" prefHeight="34.0" prefWidth="90.0" style="-fx-background-color: #00AA99; -fx-text-fill: #FFFFFF; -fx-font-family: 'Courier New'; -fx-font-size: 11.5px; -fx-font-weight: bold; -fx-border-color: #008877; -fx-border-width: 1; -fx-background-radius: 2; -fx-border-radius: 2;" text="⟳  LIMPIAR">
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                </Button>
                            </children>
                        </HBox>

                    </children>
                </AnchorPane>

            </items>
        </SplitPane>

        <!-- ══ BOTTOM ACCENT STRIP ══ -->
        <Pane prefHeight="6.0" prefWidth="850.0" style="-fx-background-color: linear-gradient(from 0% 0% to 100% 0%, #0066CC, #00AA99);" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" />

    </children>
</AnchorPane>
