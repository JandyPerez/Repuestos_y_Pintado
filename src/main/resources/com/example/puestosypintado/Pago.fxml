<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="450.0" prefWidth="750.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.puestosypintado.controladores.FacturacionController">
    <children>
        <SplitPane dividerPositions="0.45" prefHeight="450.0" prefWidth="750.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <items>
                <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="160.0" prefWidth="100.0">
                    <children>
                        <TableView fx:id="tvFacturas" prefHeight="200.0" prefWidth="200.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                            <columns>
                                <TableColumn fx:id="colNumFac" prefWidth="70.0" text="Factura #" />
                                <TableColumn fx:id="colClienteFac" prefWidth="150.0" text="Cliente" />
                                <TableColumn fx:id="colEstadoFac" prefWidth="90.0" text="Estado" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </AnchorPane>

                <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="160.0" prefWidth="100.0">
                    <children>
                        <Label layoutX="17.0" layoutY="20.0" text="Facturación y Cobros">
                            <font><Font name="Elephant" size="17.0" /></font>
                        </Label>

                        <Label layoutX="40.0" layoutY="70.0" text="Buscar Factura" />
                        <TextField fx:id="txtBuscarFac" layoutX="140.0" layoutY="66.0" prefWidth="100.0" promptText="Nro. Factura" />
                        <Button layoutX="250.0" layoutY="66.0" mnemonicParsing="false" onAction="#fnBuscarFactura" text="🔍" />

                        <Label layoutX="40.0" layoutY="110.0" text="Cliente" />
                        <TextField fx:id="txtClienteInfo" disable="true" layoutX="140.0" layoutY="106.0" prefHeight="25.0" prefWidth="117.0" />

                        <Label layoutX="40.0" layoutY="145.0" text="Monto Total" />
                        <TextField fx:id="txtTotalFac" disable="true" layoutX="140.0" layoutY="141.0" prefHeight="25.0" prefWidth="77.0" />

                        <Label layoutX="40.0" layoutY="180.0" text="Balance Pendiente" />
                        <TextField fx:id="txtBalance" disable="true" layoutX="140.0" layoutY="176.0" prefHeight="25.0" prefWidth="77.0" style="-fx-text-inner-color: red;" />

                        <Label layoutX="40.0" layoutY="225.0" text="Registrar Pago">
                            <font><Font name="System Bold" size="12.0" /></font>
                        </Label>

                        <Label layoutX="40.0" layoutY="255.0" text="Monto a Abonar" />
                        <TextField fx:id="txtAbono" layoutX="140.0" layoutY="251.0" prefHeight="25.0" prefWidth="80.0" />

                        <Label layoutX="40.0" layoutY="290.0" text="Método" />
                        <ComboBox fx:id="cmbMetodoPago" layoutX="140.0" layoutY="286.0" prefWidth="150.0" promptText="Efectivo, Tarjeta..." />

                        <HBox alignment="CENTER" layoutX="10.0" layoutY="350.0" prefHeight="35.0" prefWidth="380.0" spacing="15.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0">
                            <children>
                                <Button mnemonicParsing="false" onAction="#fnAplicarPago" prefHeight="25.0" prefWidth="90.0" style="-fx-background-color: rgb(149, 222, 159, 0.5);" text="Aplicar Pago" textFill="#44865a" />
                                <Button mnemonicParsing="false" onAction="#fnReemitirFac" prefHeight="25.0" prefWidth="80.0" style="-fx-background-color: rgb(255, 244, 149, 0.5);" text="Reemitir" textFill="#9ea14d" />
                                <Button mnemonicParsing="false" onAction="#fnAnularFactura" prefHeight="25.0" prefWidth="80.0" style="-fx-background-color: rgb(255, 130, 130, 0.5);" text="Anular Fac" textFill="#904545" />
                                <Button mnemonicParsing="false" onAction="#fnLimpiarPagos" prefHeight="25.0" prefWidth="80.0" style="-fx-background-color: rgb(126, 190, 224, 0.5);" text="Limpiar" textFill="#4da198" />
                            </children>
                        </HBox>
                    </children>
                </AnchorPane>
            </items>
        </SplitPane>
    </children>
</AnchorPane>
