<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.shape.Line?>

<AnchorPane prefHeight="450.0" prefWidth="750.0" style="-fx-background-color: #F0F5FB;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.puestosypintado.controladores.FacturacionController">

    <children>

        <!-- ══ HEADER BAR ══ -->
        <Pane prefHeight="48.0" prefWidth="750.0" style="-fx-background-color: linear-gradient(from 0% 0% to 100% 0%, #0066CC, #00AA99);" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Label layoutX="20.0" layoutY="10.0" style="-fx-font-family: 'Impact'; -fx-font-size: 20px; -fx-text-fill: #FFFFFF; -fx-font-weight: bold;" text="💳  FACTURACIÓN Y COBROS" />
                <Label layoutX="430.0" layoutY="17.0" style="-fx-font-family: 'Courier New'; -fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.85); -fx-font-weight: bold;" text="FERRETERÍA — REGISTRO DE PAGOS" />
            </children>
        </Pane>

        <!-- ══ MAIN SPLIT PANE ══ -->
        <SplitPane dividerPositions="0.45" layoutY="48.0" prefHeight="396.0" prefWidth="750.0" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 0;" AnchorPane.bottomAnchor="6.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="48.0">
            <items>

                <!-- ══ LEFT PANEL — TABLE ══ -->
                <AnchorPane minHeight="0.0" minWidth="0.0" style="-fx-background-color: #E8F1F8; -fx-border-color: #0066CC; -fx-border-width: 0 2 0 0;">
                    <children>
                        <Label layoutX="10.0" layoutY="10.0" style="-fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #0066CC;" text="▌ LISTADO" />

                        <TableView fx:id="tvFacturas" layoutY="32.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #B3D9FF; -fx-border-width: 1; -fx-selection-bar: #0066CC; -fx-selection-bar-non-focused: #66B2FF; -fx-faint-focus-color: transparent;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="32.0">
                            <columns>
                                <TableColumn fx:id="colid" prefWidth="70.0" text="FACTURA " />
                                <TableColumn fx:id="colClienteFac" prefWidth="150.0" text="CLIENTE" />
                                <TableColumn fx:id="colestado" prefWidth="90.0" text="ESTADO" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </AnchorPane>

                <!-- ══ RIGHT PANEL — FORM ══ -->
                <AnchorPane minHeight="0.0" minWidth="0.0" style="-fx-background-color: #F8FCFF;">
                    <children>

                        <!-- ── BUSCAR FACTURA ── -->
                        <Label layoutX="20.0" layoutY="18.0" style="-fx-font-family: 'Courier New'; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #0066CC;" text="NRO. FACTURA" />
                        <TextField fx:id="txtBuscarFac" layoutX="120.0" layoutY="12.0" prefHeight="28.0" prefWidth="100.0" promptText="Nro. Factura" style="-fx-background-color: #FFFFFF; -fx-border-color: transparent transparent #0066CC transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #003D99; -fx-font-family: 'Courier New'; -fx-font-size: 12px; -fx-prompt-text-fill: #9999CC;" />
                        <Button layoutX="228.0" layoutY="12.0" onAction="#fnBuscarFactura" prefHeight="28.0" prefWidth="34.0" style="-fx-background-color: #0066CC; -fx-text-fill: #FFFFFF; -fx-font-size: 13px; -fx-background-radius: 2;" text="🔍">
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                        </Button>

                        <!-- ── SEPARATOR 1 ── -->
                        <Line endX="390.0" endY="0.0" layoutY="50.0" startX="20.0" startY="0.0" style="-fx-stroke: #0066CC; -fx-opacity: 0.3;" />

                        <!-- ── CLIENTE ── -->
                        <Label layoutX="20.0" layoutY="63.0" style="-fx-font-family: 'Courier New'; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="CLIENTE" />
                        <TextField fx:id="txtClienteInfo" layoutX="120.0" layoutY="59.0" prefHeight="28.0" prefWidth="240.0" style="-fx-background-color: #FFFFFF; -fx-border-color: transparent transparent #D9E8F5 transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #1A1A1A; -fx-font-family: 'Courier New'; -fx-font-size: 12px;" />

                        <!-- ── MONTO TOTAL ── -->
                        <Label layoutX="20.0" layoutY="101.0" style="-fx-font-family: 'Courier New'; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="MONTO TOTAL" />
                        <TextField fx:id="txttotal" disable="true" layoutX="120.0" layoutY="97.0" prefHeight="28.0" prefWidth="130.0" style="-fx-background-color: #F0F5FB; -fx-border-color: transparent transparent #D9E8F5 transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #1A1A1A; -fx-font-family: 'Courier New'; -fx-font-size: 12px;" />

                        <!-- ── BALANCE PENDIENTE ── -->
                        <Label layoutX="20.0" layoutY="139.0" style="-fx-font-family: 'Courier New'; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="BAL. PENDIENTE" />
                        <TextField fx:id="txtmonto" disable="true" layoutX="120.0" layoutY="135.0" prefHeight="28.0" prefWidth="130.0" style="-fx-background-color: #FFF5F5; -fx-border-color: transparent transparent #FF9999 transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #CC0000; -fx-font-family: 'Courier New'; -fx-font-size: 12px; -fx-font-weight: bold;" />

                        <!-- ── SEPARATOR 2 ── -->
                        <Line endX="390.0" endY="0.0" layoutY="214.0" startX="20.0" startY="0.0" style="-fx-stroke: #0066CC; -fx-opacity: 0.3;" />

                        <!-- ── SECCIÓN REGISTRAR PAGO ── -->
                        <Label layoutX="20.0" layoutY="224.0" style="-fx-font-family: 'Courier New'; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #0066CC;" text="▌ REGISTRAR PAGO" />

                        <!-- ── MONTO A ABONAR ── -->
                        <Label layoutX="20.0" layoutY="248.0" style="-fx-font-family: 'Courier New'; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="MONTO ABONO" />
                        <TextField fx:id="txtAbono" layoutX="120.0" layoutY="244.0" prefHeight="28.0" prefWidth="130.0" style="-fx-background-color: #FFFFFF; -fx-border-color: transparent transparent #D9E8F5 transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #1A1A1A; -fx-font-family: 'Courier New'; -fx-font-size: 12px;" />

                        <!-- ── MÉTODO PAGO ── -->
                        <Label layoutX="20.0" layoutY="286.0" style="-fx-font-family: 'Courier New'; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="MÉTODO" />
                        <ComboBox fx:id="cmbmetodo_pago" layoutX="120.0" layoutY="282.0" prefHeight="28.0" prefWidth="160.0" promptText="Efectivo, Tarjeta..." style="-fx-background-color: #FFFFFF; -fx-border-color: #0066CC; -fx-border-width: 1;" />

                        <!-- ── Estado ── -->
                        <Label layoutX="20.0" layoutY="177.0" style="-fx-font-family: 'Courier New'; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="ESTADO" />


                        <!-- ── SEPARATOR 3 ── -->
                        <Line endX="390.0" endY="0.0" layoutX="5.0" layoutY="328.0" startX="20.0" startY="0.0" style="-fx-stroke: #0066CC; -fx-opacity: 0.3;" />

                        <!-- ── ACTION BUTTONS ── -->
                        <HBox alignment="CENTER" layoutX="10.0" layoutY="337.0" prefHeight="42.0" prefWidth="400.0" spacing="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0">
                            <children>
                                <Button mnemonicParsing="false" onAction="#fnAplicarPago" prefHeight="34.0" prefWidth="126.0" style="-fx-background-color: #00AA77; -fx-text-fill: #FFFFFF; -fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-font-weight: bold; -fx-border-color: #009966; -fx-border-width: 1; -fx-background-radius: 2; -fx-border-radius: 2;" text="💾  APLICAR PAGO">
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                </Button>
                                <Button mnemonicParsing="false" onAction="#fnAnularFactura" prefHeight="34.0" prefWidth="110.0" style="-fx-background-color: #FF6B6B; -fx-text-fill: #FFFFFF; -fx-font-family: 'Courier New'; -fx-font-size: 11.5px; -fx-font-weight: bold; -fx-border-color: #E63939; -fx-border-width: 1; -fx-background-radius: 2; -fx-border-radius: 2;" text="🗑  ANULAR FAC.">
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                </Button>
                                <Button mnemonicParsing="false" onAction="#fnLimpiarPagos" prefHeight="34.0" prefWidth="90.0" style="-fx-background-color: #00AA99; -fx-text-fill: #FFFFFF; -fx-font-family: 'Courier New'; -fx-font-size: 11.5px; -fx-font-weight: bold; -fx-border-color: #008877; -fx-border-width: 1; -fx-background-radius: 2; -fx-border-radius: 2;" text="⟳  LIMPIAR">
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                </Button>
                            </children>
                        </HBox>
                  <TextField fx:id="cmbestado" disable="true" editable="false" layoutX="120.0" layoutY="171.0" prefHeight="28.0" prefWidth="160.0" style="-fx-background-color: #FFFFFF; -fx-border-color: transparent transparent #D9E8F5 transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #1A1A1A; -fx-font-family: 'Courier New'; -fx-font-size: 12px;" />

                    </children>
                </AnchorPane>

            </items>
        </SplitPane>

        <!-- ══ BOTTOM ACCENT STRIP ══ -->
        <Pane prefHeight="6.0" prefWidth="750.0" style="-fx-background-color: linear-gradient(from 0% 0% to 100% 0%, #0066CC, #00AA99);" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" />

    </children>
</AnchorPane>
