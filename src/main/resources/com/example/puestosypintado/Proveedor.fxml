                        <Label layoutX="20.0" layoutY="63.0" style="-fx-font-family: Courier New; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="RNC / NIT *" />
                        <TextField fx:id="txtRncProv" layoutX="120.0" layoutY="59.0" prefHeight="28.0" prefWidth="160.0" style="-fx-background-color: #FFFFFF; -fx-border-color: transparent transparent #D9E8F5 transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #1A1A1A; -fx-font-family: Courier New; -fx-font-size: 12px;" />

                        <!-- EMPRESA -->
                        <Label layoutX="20.0" layoutY="101.0" style="-fx-font-family: Courier New; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="EMPRESA *" />
                        <TextField fx:id="txtEmpresaProv" layoutX="120.0" layoutY="97.0" prefHeight="28.0" prefWidth="295.0" style="-fx-background-color: #FFFFFF; -fx-border-color: transparent transparent #D9E8F5 transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #1A1A1A; -fx-font-family: Courier New; -fx-font-size: 12px;" />

                        <!-- DIRECCIÓN -->
                        <Label layoutX="20.0" layoutY="139.0" style="-fx-font-family: Courier New; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="DIRECCION" />
