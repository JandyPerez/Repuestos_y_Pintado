<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="500.0" prefWidth="850.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.puestosypintado.controladores.EmpleadoController">
    <children>
        <SplitPane dividerPositions="0.45" prefHeight="500.0" prefWidth="850.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <items>
                <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="160.0" prefWidth="100.0">
                    <children>
                        <TableView fx:id="tvEmpleados" prefHeight="200.0" prefWidth="200.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                            <columns>
                                <TableColumn fx:id="colNombreEmp" prefWidth="150.0" text="Nombre" />
                                <TableColumn fx:id="colPuestoEmp" prefWidth="100.0" text="Puesto" />
                                <TableColumn fx:id="colTelEmp" prefWidth="80.0" text="Teléfono" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </AnchorPane>

                <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="160.0" prefWidth="100.0">
                    <children>
                        <Label layoutX="17.0" layoutY="20.0" text="Gestión de Empleados">
                            <font><Font name="Elephant" size="17.0" /></font>
                        </Label>

                        <Label layoutX="40.0" layoutY="70.0" text="ID Empleado" />
                        <TextField fx:id="txtIdEmp" layoutX="130.0" layoutY="66.0" prefWidth="100.0" />
                        <Button layoutX="240.0" layoutY="66.0" mnemonicParsing="false" onAction="#fnBuscarEmpleado" text="🔍" />

                        <Label layoutX="40.0" layoutY="105.0" text="Nombre" />
                        <TextField fx:id="txtNombreEmp" layoutX="130.0" layoutY="101.0" prefWidth="280.0" />

                        <Label layoutX="40.0" layoutY="140.0" text="Cédula / RNC" />
                        <TextField fx:id="txtCedulaEmp" layoutX="130.0" layoutY="136.0" prefWidth="150.0" />

                        <Label layoutX="40.0" layoutY="175.0" text="Dirección" />
                        <TextField fx:id="txtDireccionEmp" layoutX="130.0" layoutY="171.0" prefWidth="280.0" />

                        <Label layoutX="40.0" layoutY="210.0" text="Teléfono" />
                        <TextField fx:id="txtTelEmp" layoutX="130.0" layoutY="206.0" prefWidth="120.0" />

                        <Label layoutX="265.0" layoutY="210.0" text="Salario" />
                        <TextField fx:id="txtSalarioEmp" layoutX="310.0" layoutY="206.0" prefWidth="100.0" />

                        <Label layoutX="40.0" layoutY="245.0" text="Correo" />
                        <TextField fx:id="txtEmailEmp" layoutX="130.0" layoutY="241.0" prefWidth="280.0" />

                        <Label layoutX="40.0" layoutY="280.0" text="Puesto" />
                        <ComboBox fx:id="cmbPuestoEmp" layoutX="130.0" layoutY="276.0" prefWidth="280.0" />

                        <Label layoutX="40.0" layoutY="315.0" text="Fecha Contrato" />
                        <DatePicker fx:id="dpFechaContratEmp" layoutX="130.0" layoutY="311.0" prefWidth="120.0" />

                        <Label layoutX="265.0" layoutY="315.0" text="Estado" />
                        <ComboBox fx:id="cmbEstadoEmp" layoutX="310.0" layoutY="311.0" prefWidth="100.0" />

                        <HBox alignment="CENTER" layoutX="10.0" layoutY="400.0" prefHeight="35.0" prefWidth="440.0" spacing="15.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0">
                            <children>
                                <Button mnemonicParsing="false" onAction="#fnGuardarEmpleado" prefHeight="25.0" prefWidth="80.0" style="-fx-background-color: rgb(149, 222, 159, 0.5);" text="Guardar" textFill="#44865a" />
                                <Button mnemonicParsing="false" onAction="#fnModificarEmpleado" prefHeight="25.0" prefWidth="80.0" style="-fx-background-color: rgb(255, 244, 149, 0.5);" text="Editar" textFill="#9ea14d" />
                                <Button mnemonicParsing="false" onAction="#fnBorrarEmpleado" prefHeight="25.0" prefWidth="80.0" style="-fx-background-color: rgb(255, 130, 130, 0.5);" text="Borrar" textFill="#904545" />
                                <Button mnemonicParsing="false" onAction="#fnLimpiarEmp" prefHeight="25.0" prefWidth="80.0" style="-fx-background-color: rgb(126, 190, 224, 0.5);" text="Limpiar" textFill="#4da198" />
                            </children>
                        </HBox>
                    </children>
                </AnchorPane>
            </items>
        </SplitPane>
    </children>
</AnchorPane>
