                        <!-- SECTOR + CIUDAD -->
                        <!-- FIX #19/#20: cmbSector1 renombrado a cmbCiudad -->
                        <Label layoutX="20.0" layoutY="179.0" style="-fx-font-family: Courier New; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="SECTOR" />
                        <ComboBox fx:id="cmbSector" layoutX="120.0" layoutY="172.0" prefHeight="28.0" prefWidth="110.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #0066CC; -fx-border-width: 1;" />

                        <Label layoutX="246.0" layoutY="179.0" style="-fx-font-family: Courier New; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="CIUDAD" />
                        <!-- FIX #19: fx:id corregido de cmbSector1 a cmbCiudad -->
                        <ComboBox fx:id="cmbCiudad" layoutX="306.0" layoutY="172.0" prefHeight="28.0" prefWidth="110.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #0066CC; -fx-border-width: 1;" />

                        <!-- TEL. EMPRESA + CORREO -->
                        <Label layoutX="20.0" layoutY="214.0" style="-fx-font-family: Courier New; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="TEL. EMPRESA" />
                        <TextField fx:id="txtTelProv" layoutX="120.0" layoutY="210.0" prefHeight="28.0" prefWidth="130.0" style="-fx-background-color: #FFFFFF; -fx-border-color: transparent transparent #D9E8F5 transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #1A1A1A; -fx-font-family: Courier New; -fx-font-size: 12px;" />

                        <Label layoutX="265.0" layoutY="214.0" style="-fx-font-family: Courier New; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="CORREO" />
