<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<AnchorPane prefHeight="700.0" prefWidth="900.0" style="-fx-background-color: #F0F5FB;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.puestosypintado.controladores.PinturaController">

    <children>

        <!-- ══ HEADER BAR ══ -->
        <Pane prefHeight="48.0" prefWidth="900.0" style="-fx-background-color: linear-gradient(from 0% 0% to 100% 0%, #0066CC, #00AA99);" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Label layoutX="20.0" layoutY="10.0" style="-fx-font-family: 'Impact'; -fx-font-size: 20px; -fx-text-fill: #FFFFFF; -fx-font-weight: bold;" text="🎨  SERVICIO DE PINTURA" />
                <Label layoutX="490.0" layoutY="17.0" style="-fx-font-family: 'Courier New'; -fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.85); -fx-font-weight: bold;" text="FERRETERÍA — ÓRDENES DE TRABAJO" />
            </children>
        </Pane>

        <!-- ══ MAIN SPLIT PANE ══ -->
        <SplitPane dividerPositions="0.35" layoutY="48.0" prefHeight="646.0" prefWidth="900.0" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 0;" AnchorPane.bottomAnchor="6.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="48.0">
            <items>

                <!-- ══ LEFT PANEL — TABLE ══ -->
                <AnchorPane minHeight="0.0" minWidth="0.0" style="-fx-background-color: #E8F1F8; -fx-border-color: #0066CC; -fx-border-width: 0 2 0 0;">
                    <children>
                        <Label layoutX="10.0" layoutY="10.0" style="-fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #0066CC;" text="▌ LISTADO" />

                        <TableView fx:id="tvOrdenes" layoutY="32.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #B3D9FF; -fx-border-width: 1; -fx-selection-bar: #0066CC; -fx-selection-bar-non-focused: #66B2FF; -fx-faint-focus-color: transparent;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="32.0">
                            <columns>
                                <TableColumn fx:id="colOT" prefWidth="60.0" text="ID #" />
                                <TableColumn fx:id="colVehiculo" prefWidth="120.0" text="VEHÍCULO" />
                                <TableColumn fx:id="colEstado" prefWidth="120.0" text="ETAPA" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </AnchorPane>

                <!-- ══ RIGHT PANEL — FORM (ScrollPane) ══ -->
                <ScrollPane fitToWidth="true" style="-fx-background-color: #F8FCFF; -fx-border-color: transparent;">
                    <content>
                        <VBox spacing="0.0" style="-fx-background-color: #F8FCFF;">
                            <padding><Insets bottom="15.0" left="15.0" right="15.0" top="10.0" /></padding>
                            <children>

                                <!-- ── ID OT ── -->
                                <HBox alignment="CENTER_LEFT" spacing="8.0" VBox.margin="0,0,4,0">
                                    <Label style="-fx-font-family: 'Courier New'; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #0066CC;" text="NO. OT" prefWidth="110.0" />
                                    <TextField fx:id="txtIdOT" disable="true" prefHeight="28.0" prefWidth="80.0" style="-fx-background-color: #F0F5FB; -fx-border-color: transparent transparent #0066CC transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #003D99; -fx-font-family: 'Courier New'; -fx-font-size: 12px;" />
                                    <Button fx:id="btnBuscarOT" onAction="#fnBuscarOT" prefHeight="28.0" prefWidth="34.0" style="-fx-background-color: #0066CC; -fx-text-fill: #FFFFFF; -fx-font-size: 13px; -fx-background-radius: 2;" text="🔍">
                                        <cursor><Cursor fx:constant="HAND" /></cursor>
                                    </Button>
                                </HBox>

                                <!-- ── SEPARATOR ── -->
                                <Line endX="540.0" endY="0.0" startX="0.0" startY="0.0" style="-fx-stroke: #0066CC; -fx-opacity: 0.3;">
                                    <VBox.margin><Insets bottom="10.0" top="6.0" /></VBox.margin>
                                </Line>

                                <!-- ── VEHÍCULO ── -->
                                <HBox alignment="CENTER_LEFT" spacing="8.0">
                                    <VBox.margin><Insets bottom="8.0" /></VBox.margin>
                                    <Label style="-fx-font-family: 'Courier New'; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="VEHÍCULO / VIN" prefWidth="110.0" />
                                    <ComboBox fx:id="cmbVehiculo" prefHeight="28.0" maxWidth="Infinity" HBox.hgrow="ALWAYS" style="-fx-background-color: #FFFFFF; -fx-border-color: #B3D9FF; -fx-border-width: 1;" />
                                </HBox>

                                <!-- ── PIEZAS GENERAL ── -->
                                <HBox alignment="CENTER_LEFT" spacing="8.0">
                                    <VBox.margin><Insets bottom="8.0" /></VBox.margin>
                                    <Label style="-fx-font-family: 'Courier New'; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="PIEZAS GENERAL" prefWidth="110.0" />
                                    <TextField fx:id="txtPiezas" prefHeight="28.0" promptText="Separe por comas ej: Puerta, Bomper" HBox.hgrow="ALWAYS" style="-fx-background-color: #FFFFFF; -fx-border-color: transparent transparent #D9E8F5 transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #1A1A1A; -fx-font-family: 'Courier New'; -fx-font-size: 12px; -fx-prompt-text-fill: #9999CC;" />
                                </HBox>

                                <!-- ── PRESUPUESTO BASE + ANTICIPO ── -->
                                <HBox alignment="CENTER_LEFT" spacing="8.0">
                                    <VBox.margin><Insets bottom="10.0" /></VBox.margin>
                                    <Label style="-fx-font-family: 'Courier New'; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="PRESUPUESTO" prefWidth="110.0" />
                                    <TextField fx:id="txtPresupuesto" prefHeight="28.0" prefWidth="100.0" promptText=" 0.00" style="-fx-background-color: #FFFFFF; -fx-border-color: transparent transparent #D9E8F5 transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #1A1A1A; -fx-font-family: 'Courier New'; -fx-font-size: 12px; -fx-prompt-text-fill: #9999CC;" />
                                    <Label style="-fx-font-family: 'Courier New'; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="ANTICIPO" />
                                    <TextField fx:id="txtAnticipo" disable="true" prefHeight="28.0" prefWidth="100.0" style="-fx-background-color: #F0F5FB; -fx-border-color: transparent transparent #D9E8F5 transparent; -fx-border-width: 0 0 2 0; -fx-text-fill: #1A1A1A; -fx-font-family: 'Courier New'; -fx-font-size: 12px;" />
                                </HBox>

                                <!-- ── SEPARATOR 2 ── -->
                                <Line endX="540.0" endY="0.0" startX="0.0" startY="0.0" style="-fx-stroke: #0066CC; -fx-opacity: 0.3;">
                                    <VBox.margin><Insets bottom="10.0" top="2.0" /></VBox.margin>
                                </Line>

                                <!-- ── SUBSERVICIOS PANEL ── -->
                                <VBox spacing="10.0" style="-fx-border-color: #B3D9FF; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 12; -fx-background-color: #EEF5FD;">
                                    <VBox.margin><Insets bottom="10.0" /></VBox.margin>
                                    <children>
                                        <Label style="-fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #0066CC;" text="▌ DETALLE Y ACLARACIÓN DE SUBSERVICIOS" />

                                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                                            <Label style="-fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="SELECCIONAR PIEZA" />
                                            <ComboBox fx:id="cmbPiezaSeleccionada" prefHeight="28.0" prefWidth="150.0" promptText="Elegir pieza..." style="-fx-background-color: #FFFFFF; -fx-border-color: #B3D9FF; -fx-border-width: 1;" />
                                            <Label style="-fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #000000;" text="COSTO PIEZA" />
                                            <TextField fx:id="txtCostoPiezaIndividual" prefHeight="28.0" prefWidth="70.0" text="150" style="-fx-background-color: #FFFFFF; -fx-border-color: transparent transparent #D9E8F5 transparent; -fx-border-width: 0 0 2 0; -fx-font-family: 'Courier New'; -fx-font-size: 12px;" />
                                        </HBox>

                                        <FlowPane hgap="15.0" vgap="8.0">
                                            <children>
                                                <CheckBox fx:id="chkLimpieza" style="-fx-font-family: 'Courier New'; -fx-font-size: 11px;" text="Limpieza ($150)" />
                                                <CheckBox fx:id="chkLijado" style="-fx-font-family: 'Courier New'; -fx-font-size: 11px;" text="Lijado ($150)" />
                                                <CheckBox fx:id="chkImprimacion" style="-fx-font-family: 'Courier New'; -fx-font-size: 11px;" text="Imprimación ($150)" />
                                                <CheckBox fx:id="chkBarnizado" style="-fx-font-family: 'Courier New'; -fx-font-size: 11px;" text="Barnizado ($150)" />
                                            </children>
                                        </FlowPane>

                                        <Button onAction="#fnAgregarSubservicio" prefHeight="30.0" style="-fx-background-color: #0066CC; -fx-text-fill: #FFFFFF; -fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-font-weight: bold; -fx-background-radius: 2;" text="＋  AÑADIR DETALLE DE PIEZA">
                                            <cursor><Cursor fx:constant="HAND" /></cursor>
                                        </Button>

                                        <TableView fx:id="tvSubservicios" prefHeight="150.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #B3D9FF; -fx-border-width: 1;">
                                            <columns>
                                                <TableColumn fx:id="colDetallePieza" prefWidth="120.0" text="PIEZA" />
                                                <TableColumn fx:id="colServicios" prefWidth="280.0" text="SERVICIOS APLICADOS" />
                                                <TableColumn fx:id="colCostoSub" prefWidth="100.0" text="COSTO TOTAL" />
                                            </columns>
                                        </TableView>

                                        <HBox alignment="CENTER_RIGHT" spacing="6.0">
                                            <Label style="-fx-font-family: 'Courier New'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #003D99;" text="TOTAL SUBSERVICIOS:" />
                                            <Label fx:id="lblTotalSubservicios" text="" style="-fx-font-family: 'Courier New'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #CC0000;" />
                                        </HBox>
                                    </children>
                                </VBox>

                                <!-- ── SEPARATOR 3 ── -->
                                <Line endX="540.0" endY="0.0" startX="0.0" startY="0.0" style="-fx-stroke: #0066CC; -fx-opacity: 0.3;">
                                    <VBox.margin><Insets bottom="10.0" top="2.0" /></VBox.margin>
                                </Line>

                                <!-- ── ACTION BUTTONS ── -->
                                <HBox alignment="CENTER" spacing="10.0">
                                    <children>
                                        <Button onAction="#fnGuardarOT" prefHeight="34.0" prefWidth="110.0" style="-fx-background-color: #00AA77; -fx-text-fill: #FFFFFF; -fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-font-weight: bold; -fx-border-color: #009966; -fx-border-width: 1; -fx-background-radius: 2; -fx-border-radius: 2;" text="💾  GUARDAR">
                                            <cursor><Cursor fx:constant="HAND" /></cursor>
                                        </Button>
                                        <Button onAction="#fnModificarOT" prefHeight="34.0" prefWidth="110.0" style="-fx-background-color: #0066CC; -fx-text-fill: #FFFFFF; -fx-font-family: 'Courier New'; -fx-font-size: 11.5px; -fx-font-weight: bold; -fx-border-color: #0052A3; -fx-border-width: 1; -fx-background-radius: 2; -fx-border-radius: 2;" text="✏  ACTUALIZAR">
                                            <cursor><Cursor fx:constant="HAND" /></cursor>
                                        </Button>
                                        <Button onAction="#fnLimpiar" prefHeight="34.0" prefWidth="110.0" style="-fx-background-color: #00AA99; -fx-text-fill: #FFFFFF; -fx-font-family: 'Courier New'; -fx-font-size: 11.5px; -fx-font-weight: bold; -fx-border-color: #008877; -fx-border-width: 1; -fx-background-radius: 2; -fx-border-radius: 2;" text="⟳  LIMPIAR">
                                            <cursor><Cursor fx:constant="HAND" /></cursor>
                                        </Button>
                                    </children>
                                </HBox>

                            </children>
                        </VBox>
                    </content>
                </ScrollPane>

            </items>
        </SplitPane>

        <!-- ══ BOTTOM ACCENT STRIP ══ -->
        <Pane prefHeight="6.0" prefWidth="900.0" style="-fx-background-color: linear-gradient(from 0% 0% to 100% 0%, #0066CC, #00AA99);" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" />

    </children>
</AnchorPane>
