<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="500.0" prefWidth="750.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.puestosypintado.controladores.VehiculoController">
    <children>
        <SplitPane dividerPositions="0.4" prefHeight="500.0" prefWidth="750.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <items>
                <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="160.0" prefWidth="100.0">
                    <children>
                        <TableView fx:id="tvVehiculos" prefHeight="200.0" prefWidth="200.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                            <columns>
                                <TableColumn fx:id="colPlaca" prefWidth="100.0" text="Placa" />
                                <TableColumn fx:id="colMarcaModelo" prefWidth="150.0" text="Marca/Modelo" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </AnchorPane>

                <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="160.0" prefWidth="100.0">
                    <children>
                        <Label layoutX="17.0" layoutY="20.0" text="Registro de Vehículos">
                            <font><Font name="Elephant" size="17.0" /></font>
                        </Label>

                        <Label layoutX="40.0" layoutY="70.0" text="ID Vehículo" />
                        <TextField fx:id="txtIdVehiculo" layoutX="120.0" layoutY="66.0" prefWidth="80.0" disable="true" />
                        <Button fx:id="btnBuscarVehiculo" layoutX="210.0" layoutY="66.0" mnemonicParsing="false" onAction="#fnBuscarVehiculo" text="🔍" />

                        <Label layoutX="40.0" layoutY="105.0" text="Cliente *" />
                        <ComboBox fx:id="cmbCliente" layoutX="120.0" layoutY="101.0" prefWidth="250.0" promptText="Seleccione Propietario" />

                        <Label layoutX="40.0" layoutY="140.0" text="Marca *" />
                        <TextField fx:id="txtMarca" layoutX="120.0" layoutY="136.0" prefWidth="110.0" />

                        <Label layoutX="240.0" layoutY="140.0" text="Modelo" />
                        <TextField fx:id="txtModelo" layoutX="290.0" layoutY="136.0" prefWidth="80.0" />

                        <Label layoutX="40.0" layoutY="175.0" text="Año" />
                        <TextField fx:id="txtAno" layoutX="120.0" layoutY="171.0" prefWidth="110.0" />

                        <Label layoutX="240.0" layoutY="175.0" text="Color" />
                        <TextField fx:id="txtColor" layoutX="290.0" layoutY="171.0" prefWidth="80.0" />

                        <Label layoutX="40.0" layoutY="210.0" text="Placa *" />
                        <TextField fx:id="txtPlaca" layoutX="120.0" layoutY="206.0" prefWidth="250.0" />

                        <Label layoutX="40.0" layoutY="245.0" text="VIN *" />
                        <TextField fx:id="txtVIN" layoutX="120.0" layoutY="241.0" prefWidth="250.0" promptText="Número de Chasis" />

                        <Label layoutX="40.0" layoutY="280.0" text="Notas" />
                        <TextArea fx:id="txtNotas" layoutX="120.0" layoutY="280.0" prefHeight="60.0" prefWidth="250.0" promptText="Detalles adicionales..." />

                        <HBox alignment="CENTER" layoutX="10.0" layoutY="370.0" prefHeight="35.0" prefWidth="380.0" spacing="15.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0">
                            <children>
                                <Button mnemonicParsing="false" onAction="#fnGuardarVehiculo" prefHeight="25.0" prefWidth="80.0" style="-fx-background-color: rgb(149, 222, 159, 0.5);" text="Guardar" textFill="#44865a" />
                                <Button mnemonicParsing="false" onAction="#fnModificarVehiculo" prefHeight="25.0" prefWidth="80.0" style="-fx-background-color: rgb(255, 244, 149, 0.5);" text="Editar" textFill="#9ea14d" />
                                <Button mnemonicParsing="false" onAction="#fnBorrarVehiculo" prefHeight="25.0" prefWidth="80.0" style="-fx-background-color: rgb(255, 130, 130, 0.5);" text="Borrar" textFill="#904545" />
                                <Button mnemonicParsing="false" onAction="#fnLimpiar" prefHeight="25.0" prefWidth="80.0" style="-fx-background-color: rgb(126, 190, 224, 0.5);" text="Limpiar" textFill="#4da198" />
                            </children>
                        </HBox>
                    </children>
                </AnchorPane>
            </items>
        </SplitPane>
    </children>
</AnchorPane>